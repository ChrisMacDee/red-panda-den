# ─── Domain ───────────────────────────────────────────────────────────────────
BASE_DOMAIN=redpandacreations.co.uk

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=lifeplatform
POSTGRES_PASSWORD=changeme
POSTGRES_DB=life_platform
DATABASE_URL=postgresql://lifeplatform:changeme@postgres:5432/life_platform

# ─── Medusa ───────────────────────────────────────────────────────────────────
MEDUSA_DB_URL=postgresql://lifeplatform:changeme@postgres:5432/medusa
MEDUSA_ADMIN_CORS=https://shop.redpandacreations.co.uk
MEDUSA_STORE_CORS=https://shop.redpandacreations.co.uk
MEDUSA_AUTH_CORS=https://shop.redpandacreations.co.uk
MEDUSA_JWT_SECRET=changeme-jwt-secret
MEDUSA_COOKIE_SECRET=changeme-cookie-secret
REDIS_URL=redis://redis:6379

# ─── Ghost ────────────────────────────────────────────────────────────────────
GHOST_URL=https://redpandacreations.co.uk
GHOST_MAIL_FROM=noreply@redpandacreations.co.uk
GHOST_MAIL_TRANSPORT=SMTP
GHOST_MAIL_HOST=smtp.example.com
GHOST_MAIL_PORT=587
GHOST_MAIL_USER=changeme
GHOST_MAIL_PASSWORD=changeme

# ─── Authelia ─────────────────────────────────────────────────────────────────
AUTHELIA_JWT_SECRET=changeme-authelia-jwt-secret
AUTHELIA_SESSION_SECRET=changeme-authelia-session-secret

# ─── Ntfy ─────────────────────────────────────────────────────────────────────
NTFY_BASE_URL=https://ntfy.redpandacreations.co.uk
NTFY_MEDICATION_TOPIC=red-panda-den-medication
NTFY_DEPLOY_TOPIC=red-panda-den-deploy

# ─── CrowdSec ─────────────────────────────────────────────────────────────────
CROWDSEC_BOUNCER_API_KEY=changeme-bouncer-key

# ─── Dashboard API ────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=production

# ─── Traefik ──────────────────────────────────────────────────────────────────
TRAEFIK_API_DASHBOARD=true
