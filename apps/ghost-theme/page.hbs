{{!< default}}

{{#page}}
<article class="container--narrow" style="padding-top:64px;padding-bottom:96px;">
  <header class="post-header" style="text-align:left;">
    <h1>{{title}}</h1>
  </header>
  {{#if feature_image}}
    <img class="post-hero-image" src="{{img_url feature_image size="l"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
  {{/if}}
  <div class="post-body">{{content}}</div>
</article>
{{/page}}
