<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">

      <div class="site-footer__brand">
        <div class="site-footer__logo-row">
          {{#if @site.logo}}
            <img class="site-footer__logo" src="{{@site.logo}}" alt="{{@site.title}}" width="32" height="32">
          {{/if}}
          <span class="site-footer__wordmark text-mono">{{@site.title}}</span>
        </div>
        <p class="site-footer__tagline">Henson-style puppet maker &amp; software developer, based in the UK.</p>
      </div>

      <div>
        <p class="site-footer__links-heading">Navigate</p>
        <ul class="site-footer__links">
          <li><a class="site-footer__link" href="{{@site.url}}">Home</a></li>
          <li><a class="site-footer__link" href="{{@site.url}}portfolio/">Portfolio</a></li>
          <li><a class="site-footer__link" href="{{@site.url}}blog/">Blog</a></li>
          <li><a class="site-footer__link" href="{{@site.url}}about/">About</a></li>
          <li><a class="site-footer__link" href="{{@site.url}}contact/">Contact</a></li>
        </ul>
      </div>

      <div>
        <p class="site-footer__cta-heading">Commission a puppet</p>
        <p class="site-footer__cta-text">After a Kermit, a Cookie Monster, or something entirely new? Let's talk.</p>
        <a href="{{@site.url}}contact/?subject=commission" class="btn btn--primary btn--sm">Start a commission →</a>
      </div>

    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copy">© {{date format="YYYY"}} {{@site.title}} · Made with too much caffeine</p>
      <button class="theme-toggle" data-theme-toggle aria-label="Toggle colour scheme" style="color:var(--text-muted)">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
  </div>
</footer>
