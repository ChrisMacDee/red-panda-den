{{!-- Usage: {{> post-card}} inside a {{#foreach posts}} loop --}}
<article class="post-card{{#if @first}} post-card--featured{{/if}}">
  <a href="{{url}}" class="post-card__image-link" tabindex="-1" aria-hidden="true">
    {{#if feature_image}}
      <img class="post-card__image" src="{{img_url feature_image size="m"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
    {{else}}
      <div class="post-card__image post-card__image--placeholder"></div>
    {{/if}}
  </a>
  <div class="post-card__body">
    <div class="post-card__meta">
      {{#has tag="puppet-build"}}
        <span class="pill pill--puppet-build">Puppet Build</span>
      {{else}}
        {{#has tag="tutorial"}}
          <span class="pill pill--tutorial">Tutorial</span>
        {{else}}
          <span class="pill pill--news">News</span>
        {{/has}}
      {{/has}}
      <span class="post-card__date">{{date published_at format="DD MMM YYYY"}}</span>
      <span class="post-card__reading-time">{{reading_time}}</span>
    </div>
    <h3 class="post-card__title"><a href="{{url}}">{{title}}</a></h3>
    <p class="post-card__excerpt">{{excerpt words="25"}}</p>
  </div>
</article>
