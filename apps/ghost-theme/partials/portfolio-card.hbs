{{!-- Usage: {{> portfolio-card}} inside a {{#foreach posts}} loop --}}
<article class="portfolio-card {{#has tag="portfolio-puppet"}}portfolio-card--puppet{{else}}portfolio-card--software{{/has}}"
         data-category="{{#has tag="portfolio-puppet"}}puppet{{else}}software{{/has}}">
  <a href="{{url}}">
    {{#if feature_image}}
      <img class="portfolio-card__image" src="{{img_url feature_image size="m"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
    {{else}}
      <div class="portfolio-card__image" style="background:var(--bg-tertiary);"></div>
    {{/if}}
  </a>
  <div class="portfolio-card__body">
    <div class="portfolio-card__meta">
      {{#has tag="portfolio-puppet"}}
        <span class="pill pill--puppet">Puppet</span>
      {{else}}
        <span class="pill pill--software">Software</span>
      {{/has}}
      <span class="post-card__date">{{date published_at format="YYYY"}}</span>
    </div>
    <h3 class="portfolio-card__title"><a href="{{url}}">{{title}}</a></h3>
    <p class="portfolio-card__desc">{{excerpt words="20"}}</p>
    {{#has tag="portfolio-software"}}
      {{#if tags}}
        <div class="tech-tags">
          {{#foreach tags}}
            {{#unless (match slug "portfolio" "portfolio-puppet" "portfolio-software")}}
              <span class="pill pill--tech">{{name}}</span>
            {{/unless}}
          {{/foreach}}
        </div>
      {{/if}}
    {{/has}}
  </div>
</article>
